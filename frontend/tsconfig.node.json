    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "outDir": "./node_modules/.cache/tsconfig-node",
    "tsBuildInfoFile": "./node_modules/.cache/tsconfig-node.tsbuildinfo"
  },
  "include": ["vite.config.ts"]
}
