# CUSTOM: Copy outside the repository or to deploy/.env.dev, then replace secrets.
DEPLOY_ENV=dev
DEV_POSTGRES_PORT=15433
DEV_REDIS_PORT=16380

# Host source backend and Vite use these ports; the dev Compose file does not
# start an application container.
SOURCE_BACKEND_PORT=18081
VITE_DEV_PORT=3000
SERVER_MODE=debug

POSTGRES_USER=sub2api_dev
POSTGRES_PASSWORD=replace_with_a_unique_dev_database_password
POSTGRES_DB=sub2api_dev

REDIS_PASSWORD=replace_with_a_unique_dev_redis_password
REDIS_DB=0

ADMIN_EMAIL=admin-dev@sub2api.local
ADMIN_PASSWORD=replace_with_a_unique_dev_admin_password
JWT_SECRET=replace_with_a_unique_64_character_dev_jwt_secret
TOTP_ENCRYPTION_KEY=replace_with_a_unique_64_character_dev_totp_key

TZ=Asia/Shanghai
