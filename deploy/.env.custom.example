# CUSTOM: Copy outside the repository or to deploy/.env.custom, then replace secrets.
DEPLOY_ENV=custom
SERVER_PORT=18080
SERVER_MODE=release

POSTGRES_USER=sub2api_custom
POSTGRES_PASSWORD=replace_with_a_unique_custom_database_password
POSTGRES_DB=sub2api_custom

REDIS_PASSWORD=replace_with_a_unique_custom_redis_password
REDIS_DB=0

ADMIN_EMAIL=admin-custom@sub2api.local
ADMIN_PASSWORD=replace_with_a_unique_custom_admin_password
JWT_SECRET=replace_with_a_unique_64_character_custom_jwt_secret
TOTP_ENCRYPTION_KEY=replace_with_a_unique_64_character_custom_totp_key

TZ=Asia/Shanghai
